  "extension_fields": {
    "description": "受控扩展字段，用于承载特定领域的业务信息；扩展字段统一以 ext_ 前缀或 ext. 命名空间承载。",
    "type": "object",
    "reserved_prefix": ["ext_", "ext."],
    "allowed_value_types": ["string", "number", "boolean", "array", "object"],
    "examples": [
      "ext_part_number",
      "ext_environment",
      "ext_customer_impact",
      "ext_test_method",
      "ext_raw_value"
    ]
  }
}
