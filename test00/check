#!/usr/bin/env bash
# check - a small script to verify OpenAI API access
# Usage:
#   export OPENAI_API_KEY="sk-..."
#   ./test00/check

set -euo pipefail

if [ -z "${OPENAI_API_KEY:-}" ]; then
  echo "ERROR: OPENAI_API_KEY not set. Export it first, e.g."
  echo "  export OPENAI_API_KEY=\"sk-...\""
  exit 2
fi

# Models to try (falls back if earlier one not available)
MODELS=(
  "gpt-5.1-codex-max"
  "gpt-4o-mini"
  "gpt-3.5-turbo"
)

ENDPOINT="https://api.openai.com/v1/chat/completions"

echo "OpenAI API check: testing models in order: ${MODELS[*]}"

for model in "${MODELS[@]}"; do
  echo
  echo "== Testing model: $model =="

  # small payload
  read -r -d '' PAYLOAD <<EOF || true
{
  "model": "$model",
  "messages": [{"role":"user","content":"Say hi and identify the model name briefly."}],
  "max_tokens": 32
}
EOF

  # Use curl: save response, print http code and a short preview
  TMPRESP=$(mktemp)
  HTTP_CODE=$(curl -sS -X POST "$ENDPOINT" \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$PAYLOAD" \
    -o "$TMPRESP" -w "%{http_code}" --connect-timeout 10 --max-time 20 || echo "000")

  if [ "$HTTP_CODE" = "000" ]; then
    echo "Network/connection error when calling API for model $model"
    rm -f "$TMPRESP"
    continue
  fi

  echo "HTTP status: $HTTP_CODE"

  if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
    # try to extract a short reply (safe JSON parse fallback)
    if command -v jq >/dev/null 2>&1; then
      preview=$(jq -r '.choices[0].message.content' "$TMPRESP" 2>/dev/null || true)
    else
      # fallback: crude extraction
      preview=$(sed -n 's/.*"content"\s*:\s*"\(.*\)".*/\1/p' "$TMPRESP" | head -n1 || true)
    fi
    echo "SUCCESS: model responded. Preview:"
    echo "---"
    echo "$preview"
    echo "---"
    rm -f "$TMPRESP"
    exit 0
  else
    echo "API returned non-2xx response for model $model. Response (first 400 bytes):"
    head -c 400 "$TMPRESP" || true
    echo
    rm -f "$TMPRESP"
    # try next model
  fi
done

echo
echo "All models attempted and none returned a successful 2xx response."
echo "If you expect free-tier access, try using a public small model (e.g. gpt-3.5-turbo) or check your API key and account limits."
echo "If you see 401/403, verify the key and that the account has access to the models."

exit 1
