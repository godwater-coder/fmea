# DFMEA RAG frontend proxy configuration

# FMEA backend API. Start it from the repository root with:
# python code/kg_rag.py
FMEA_API_BASE=http://127.0.0.1:8080/api/v1

# CSV path sent to the FMEA backend when building the graph.
# Keep this relative path when the backend is started from the repository root.
FMEA_DEFAULT_CSV=data/dfmea_final.csv

# Proxy timeouts in seconds.
FMEA_TIMEOUT=90
FMEA_BUILD_TIMEOUT=300

# Flask development settings for rag_frontend/server.py.
FLASK_ENV=development
FLASK_DEBUG=1
